# agent_evolve — LLM-driven multi-objective optimisation
# =====================================================
# Procedures: kedi DSL prompts for LLM interaction.
# Main block: calls into Python (agent_evolve.loop) passing procedures.
#
# Contract: a module named `problem_def` must be importable and expose:
#   problem         — object satisfying the agent_evolve Problem protocol
#   config          — dict with search hyper-parameters
#   CandidateConfig — Pydantic model for one candidate (from problem.candidate_model)

```
from problem_def import problem, config, CandidateConfig

from agent_evolve._support import format_search_space_description
from agent_evolve.loop import run_evolution_loop

def _cfg(key, default):
    return config.get(key, default) if isinstance(config, dict) else getattr(config, key, default)

pop_size = _cfg("pop_size", 8)
generations = _cfg("generations", 5)
candidates_per_batch = _cfg("candidates_per_batch", 5)
max_regen_rounds = _cfg("max_regen_rounds", 10)
max_failed_examples = _cfg("max_failed_examples", 5)
verbose = _cfg("verbose", True)
llm_retries = _cfg("llm_retries", 3)

objectives = list(problem.objectives)
assert objectives, "Problem must define at least one objective"

problem_desc = None
if hasattr(problem, "search_space_description"):
    problem_desc = problem.search_space_description()

search_space_desc = format_search_space_description(
    objectives,
    config_schema=_cfg("config_schema", None),
    example_config=_cfg("example_config", None),
    constraints=_cfg("constraints_description", None),
    problem_description=problem_desc,
)

def log(msg):
    if verbose:
        print(msg, flush=True)

result = None
```

# ============================================================================
# LLM procedures
# ============================================================================

@generate_initial_candidates(search_space_desc: str, n_candidates: int) -> `list[CandidateConfig]`:
    You are an optimization expert generating candidates for a multi-objective optimization problem.\n\n\
    <search_space_desc>\n\n\
    Generate exactly <n_candidates> different configuration candidates that:\n\
    1. Are diverse and explore different regions of the search space\n\
    2. Are likely to be valid (satisfy any constraints)\n\
    3. Trade off between different objectives\n\n\
    Each candidate must strictly match the Pydantic schema CandidateConfig (field names, types, required fields).\n\n\
    [thought_process]: Your strategy for generating diverse, valid initial candidates.\n\
    [candidates: `list[CandidateConfig]`]: Exactly <n_candidates> full configuration objects — no empty placeholders.

    = `candidates`


@regenerate_candidates(failed_str: str, n_candidates: int, search_space_desc: str, constraint_instruction: str, performance_insights: str) -> `list[CandidateConfig]`:
    You are an optimization expert. Previous candidates failed validation. Learn from the failures and generate better candidates.\n\n\
    <search_space_desc>\n\n\
    FAILED CANDIDATES AND THEIR ISSUES:\n\
    <failed_str>\n\n\
    CONSTRAINT COMPLIANCE INSTRUCTIONS:\n\
    <constraint_instruction>\n\n\
    PERFORMANCE INSIGHTS:\n\
    <performance_insights>\n\n\
    Generate exactly <n_candidates> NEW configuration candidates that:\n\
    1. Address the issues from the failed candidates\n\
    2. Follow the constraint instructions\n\
    3. Are likely to be valid\n\n\
    Each candidate must strictly match CandidateConfig.\n\n\
    [thought_process]: How you are addressing the failures in these new candidates.\n\
    [candidates: `list[CandidateConfig]`]: Exactly <n_candidates> full configuration objects.

    = `candidates`


@generate_offspring(pareto_str: str, n_candidates: int, search_space_desc: str, constraint_instruction: str, performance_insights: str) -> `list[CandidateConfig]`:
    You are an optimization expert. Generate offspring candidates based on high-quality Pareto-optimal configurations.\n\n\
    <search_space_desc>\n\n\
    PARETO-OPTIMAL CONFIGURATIONS (best performers so far):\n\
    <pareto_str>\n\n\
    CONSTRAINT COMPLIANCE INSTRUCTIONS:\n\
    <constraint_instruction>\n\n\
    PERFORMANCE INSIGHTS:\n\
    <performance_insights>\n\n\
    Generate exactly <n_candidates> NEW configuration candidates that:\n\
    1. Build upon the patterns in the Pareto configurations\n\
    2. Explore new trade-offs between objectives\n\
    3. Follow the constraint instructions\n\
    4. Try to improve on existing solutions\n\n\
    Each candidate must strictly match CandidateConfig.\n\n\
    [thought_process]: How you are creating offspring that build on and improve the Pareto configurations.\n\
    [candidates: `list[CandidateConfig]`]: Exactly <n_candidates> full configuration objects.

    = `candidates`


@regenerate_offspring(failed_str: str, pareto_str: str, n_candidates: int, search_space_desc: str, constraint_instruction: str, performance_insights: str) -> `list[CandidateConfig]`:
    You are an optimization expert. Some offspring candidates failed. Learn from the failures while using the Pareto front as guidance.\n\n\
    <search_space_desc>\n\n\
    PARETO-OPTIMAL CONFIGURATIONS (reference for valid, high-quality solutions):\n\
    <pareto_str>\n\n\
    FAILED OFFSPRING AND THEIR ISSUES:\n\
    <failed_str>\n\n\
    CONSTRAINT COMPLIANCE INSTRUCTIONS:\n\
    <constraint_instruction>\n\n\
    PERFORMANCE INSIGHTS:\n\
    <performance_insights>\n\n\
    Generate exactly <n_candidates> NEW configuration candidates that:\n\
    1. Address the issues from the failed candidates\n\
    2. Stay close to the Pareto configurations (which are known to be valid)\n\
    3. Follow the constraint instructions\n\
    4. Try to improve on existing solutions\n\n\
    Each candidate must strictly match CandidateConfig.\n\n\
    [thought_process]: How you are fixing the failures while building on Pareto patterns.\n\
    [candidates: `list[CandidateConfig]`]: Exactly <n_candidates> full configuration objects.

    = `candidates`


@generate_failure_insights(failed_str: str, search_space_desc: str, n_failed: int) -> list:
    You are an optimization expert. Analyze why these candidates failed and provide specific insights.\n\n\
    <search_space_desc>\n\n\
    FAILED CANDIDATES:\n\
    <failed_str>\n\n\
    For each failed candidate, provide a specific insight about:\n\
    1. What constraint or requirement it violated\n\
    2. How to fix it in future candidates\n\n\
    [insights: list[str]]: A JSON list of exactly <n_failed> insight strings, one for each failed candidate in order.

    = `insights`


@generate_constraint_instruction(failed_str: str, search_space_desc: str) -> str:
    You are an optimization expert. Based on these failed candidates, create a consolidated set of constraint instructions.\n\n\
    <search_space_desc>\n\n\
    FAILED CANDIDATES AND INSIGHTS:\n\
    <failed_str>\n\n\
    Create a clear, actionable set of instructions that future candidates should follow to avoid these failures.\n\n\
    [constraint_instruction: str]: A detailed paragraph describing how to satisfy constraints when proposing configurations.

    = `constraint_instruction`


@update_constraint_instruction(previous_instruction: str, failed_str: str, search_space_desc: str) -> str:
    You are an optimization expert. Update the constraint instructions based on new failures.\n\n\
    PREVIOUS CONSTRAINT INSTRUCTIONS:\n\
    <previous_instruction>\n\n\
    NEW FAILED CANDIDATES:\n\
    <failed_str>\n\n\
    Update the constraint instructions to incorporate insights from these new failures.\n\n\
    [updated_instruction: str]: An updated, comprehensive set of constraint instructions.

    = `updated_instruction`


@generate_performance_insights(stats_str: str, search_space_desc: str) -> str:
    You are an optimization expert. Analyze the performance patterns and provide insights for generating better candidates.\n\n\
    <search_space_desc>\n\n\
    PERFORMANCE STATISTICS:\n\
    <stats_str>\n\n\
    Analyze:\n\
    1. What patterns make configurations perform well?\n\
    2. What trade-offs exist between objectives?\n\
    3. What configuration choices lead to good overall performance?\n\n\
    [performance_insights: str]: A detailed analysis of what makes configurations perform well and how to generate better candidates.

    = `performance_insights`


@update_performance_insights(previous_insights: str, pareto_str: str, total_valid: int, pareto_size: int) -> str:
    You are an optimization expert. Update the performance insights based on new results.\n\n\
    PREVIOUS INSIGHTS:\n\
    <previous_insights>\n\n\
    CURRENT TOP PARETO CONFIGURATIONS:\n\
    <pareto_str>\n\n\
    TOTAL VALID CANDIDATES: <total_valid>\n\
    PARETO FRONT SIZE: <pareto_size>\n\n\
    Update the insights with any new patterns or observations.\n\n\
    [updated_insights: str]: Updated performance insights incorporating the new results.

    = `updated_insights`


# ============================================================================
# Main: hand procedures to the Python loop
# ============================================================================

```
import problem_def as _pd

result = run_evolution_loop(
    problem=problem,
    objectives=objectives,
    search_space_desc=search_space_desc,
    pop_size=pop_size,
    generations=generations,
    candidates_per_batch=candidates_per_batch,
    max_regen_rounds=max_regen_rounds,
    max_failed_examples=max_failed_examples,
    generate_initial_candidates=generate_initial_candidates,
    regenerate_candidates=regenerate_candidates,
    generate_offspring=generate_offspring,
    regenerate_offspring=regenerate_offspring,
    generate_failure_insights=generate_failure_insights,
    generate_constraint_instruction=generate_constraint_instruction,
    update_constraint_instruction=update_constraint_instruction,
    generate_performance_insights=generate_performance_insights,
    update_performance_insights=update_performance_insights,
    log=log,
    llm_retries=llm_retries,
)

_pd._result = result
```

= `result`
